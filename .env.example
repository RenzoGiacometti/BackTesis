# Application
NODE_ENV=development
# El frontend (PluvIAFront) espera la API en el puerto 3001
PORT=3001

# Database - PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pluvia_db?schema=public"

# JWT Access Token (short-lived)
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_ACCESS_EXPIRATION=15m

# JWT Refresh Token (long-lived)
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRATION=7d
